{
  "name": "speedskate-meet",
  "version": "7.2.0",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "desktop:start": "electron desktop/main.js",
    "desktop:dev": "SSM_DESKTOP_DEV=1 electron desktop/main.js",
    "desktop:icon": "node scripts/create-mac-icon.js",
    "desktop:package": "npm run desktop:icon && electron-builder --mac dir && node scripts/desktop-alpha-output.js",
    "desktop:build": "npm run desktop:package"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.1",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.speedskateleague.speedskatemeet",
    "productName": "SpeedSkateMeet",
    "copyright": "Copyright © 2026 SpeedSkateMeet",
    "directories": {
      "output": "dist"
    },
    "files": [
      "server.js",
      "desktop/**/*",
      "routes/**/*",
      "services/**/*",
      "utils/**/*",
      "views/**/*",
      "public/**/*",
      "migrations/**/*",
      "src/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "desktop/main.js",
      "version": "0.1.0-alpha"
    },
    "mac": {
      "category": "public.app-category.sports",
      "icon": "desktop/assets/icon.png",
      "target": [
        {
          "target": "dir"
        }
      ]
    }
  }
}
