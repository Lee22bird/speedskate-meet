{
  "name": "speedskate-meet",
  "version": "7.2.0",
  "description": "SpeedSkateMeet desktop meet operations app.",
  "author": "Speed Skate League",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "desktop:start": "electron desktop/main.js",
    "desktop:dev": "SSM_DESKTOP_DEV=1 electron desktop/main.js",
    "desktop:icon": "node scripts/create-mac-icon.js",
    "desktop:package": "npm run package:mac",
    "desktop:build": "npm run build:mac",
    "build": "npm run build:mac",
    "build:mac": "npm run desktop:icon && electron-builder --config electron-builder.yml --config.directories.output=/private/tmp/ssm-desktop-release/mac --mac --arm64",
    "build:mac:intel": "npm run desktop:icon && electron-builder --config electron-builder.yml --config.directories.output=/private/tmp/ssm-desktop-release/mac --mac --x64",
    "package:mac": "npm run desktop:icon && electron-builder --config electron-builder.yml --config.directories.output=/private/tmp/ssm-desktop-release/mac --mac dir --arm64",
    "package:mac:intel": "npm run desktop:icon && electron-builder --config electron-builder.yml --config.directories.output=/private/tmp/ssm-desktop-release/mac --mac dir --x64",
    "notarize": "node scripts/notarize-mac.js",
    "release:mac": "npm run build:mac && npm run notarize"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.1",
    "electron-updater": "^6.8.9",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@electron/notarize": "2.5.0",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3"
  }
}
